<?php
session_start();
error_reporting(E_ALL);
ini_set('display_errors', 1);

// --- INICIALIZAR CARRITO SI NO EXISTE ---
if (!isset($_SESSION['carrito']) || !is_array($_SESSION['carrito'])) {
    $_SESSION['carrito'] = [];
}

// --- AGREGAR O ACTUALIZAR PRODUCTO EN EL CARRITO ---
if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['agregar_al_carrito'])) {
    // Obtener y limpiar datos del formulario
    $id_catalogo = isset($_POST['id_catalogo']) ? trim($_POST['id_catalogo']) : '';
    $descripcion = isset($_POST['descripcion']) ? trim($_POST['descripcion']) : '';
    $precio = isset($_POST['precio']) ? (float)preg_replace('/[^0-9.]/', '', $_POST['precio']) : 0;

    // Solo continuar si los datos son válidos
    if (!empty($id_catalogo) && !empty($descripcion) && $precio > 0) {
        $producto_nuevo = [
            'id_catalogo' => $id_catalogo,
            'descripcion' => $descripcion,
            'precio' => $precio,
            'cantidad' => 1
        ];

        // Verificar si el producto ya existe en el carrito
        $existe = false;
        foreach ($_SESSION['carrito'] as $key => $item) {
            if ($item['id_catalogo'] === $id_catalogo) {
                $_SESSION['carrito'][$key]['cantidad']++;
                $existe = true;
                break;
            }
        }

        // Agregar producto nuevo si no existe
        if (!$existe) {
            $_SESSION['carrito'][] = $producto_nuevo;
        }

        // Redirigir para evitar reenvíos de formulario
        header('Location: carrito.php');
        exit();
    }
}

// --- ELIMINAR PRODUCTO DEL CARRITO ---
if (isset($_GET['eliminar']) && is_numeric($_GET['eliminar'])) {
    $indice = (int)$_GET['eliminar'];
    if (isset($_SESSION['carrito'][$indice])) {
        unset($_SESSION['carrito'][$indice]);
        // Reorganizar índices para evitar espacios vacíos
        $_SESSION['carrito'] = array_values($_SESSION['carrito']);
    }
    header('Location: carrito.php');
    exit();
}

// --- CALCULAR TOTAL GENERAL ---
$total_general = 0;
if (!empty($_SESSION['carrito'])) {
    foreach ($_SESSION['carrito'] as $item) {
        $subtotal = (float)$item['precio'] * (int)$item['cantidad'];
        $total_general += $subtotal;
    }
}
